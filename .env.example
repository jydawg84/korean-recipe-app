# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://postgres:your_password_here@db.xxxxx.supabase.co:5432/postgres
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_***
BASE_URL=http://localhost:3000
AUTH_SECRET=your_random_auth_secret_here   # Generate a new one for production later

# Optional: Add your Anthropic API key to enable real AI recipe generation
# Without this key, the app still works with 6 built-in demo Korean recipes
ANTHROPIC_API_KEY=sk-ant-***
